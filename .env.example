# ─── Supabase ──────────────────────────────────────────────────────────────────
# Find these in: Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Sentry ────────────────────────────────────────────────────────────────────
# Find the DSN in: Sentry → Project → Settings → Client Keys (DSN)
VITE_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz

# Only needed for uploading source maps during `npm run build` (CI/CD use)
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug

# ─── Storage ───────────────────────────────────────────────────────────────────
# Namespace prefix for storage keys
VITE_STORAGE_PREFIX=resume-app

# Storage schema version — bump when making breaking data changes
VITE_STORAGE_VERSION=1.0

# ─── Optional: custom HTTP backend ─────────────────────────────────────────────
# Uncomment to use a custom API instead of Supabase
# VITE_API_BASE_URL=https://api.yoursite.com
